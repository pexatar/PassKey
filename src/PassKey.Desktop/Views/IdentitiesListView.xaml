<UserControl
    x:Class="PassKey.Desktop.Views.IdentitiesListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PassKey.Desktop.Controls"
    KeyDown="OnViewKeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="DetailColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <!-- List area -->
        <Grid Grid.Column="0" Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header: Title + Search + Add button -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Uid="PageIdentities" Grid.Column="0" Text="Identità"
                           Style="{StaticResource TitleTextBlockStyle}"
                           VerticalAlignment="Center"
                           AutomationProperties.HeadingLevel="Level1" />

                <AutoSuggestBox x:Uid="SearchIdentities" Grid.Column="1"
                                x:Name="SearchBox"
                                PlaceholderText="Cerca identità..."
                                QueryIcon="Find"
                                MaxWidth="300"
                                HorizontalAlignment="Right"
                                TextChanged="SearchBox_TextChanged"
                                AutomationProperties.Name="Cerca identità" />

                <Button Grid.Column="2"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="AddButton_Click"
                        AutomationProperties.Name="Aggiungi identità"
                        ToolTipService.ToolTip="Aggiungi identità (Ctrl+N)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock x:Uid="AddIdentity" Text="Aggiungi identità" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Card grid + empty state -->
            <Grid Grid.Row="1">

                <!-- Empty state -->
                <controls:EmptyStateControl
                    x:Uid="EmptyIdentities"
                    x:Name="EmptyState"
                    Visibility="Collapsed"
                    Icon="&#xE77B;"
                    Title="Nessuna identità"
                    Subtitle="Aggiungi la tua prima identità per salvare dati personali, indirizzi e documenti."
                    PrimaryActionText="Aggiungi identità" />

                <!-- Identity GridView (card layout) -->
                <GridView x:Name="IdentityList"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="IdentityList_ItemClick"
                          ContainerContentChanging="IdentityList_ContainerContentChanging">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           MaximumRowsOrColumns="6" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,12,12" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <!-- Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Width="270"
                                    PointerEntered="Card_PointerEntered"
                                    PointerExited="Card_PointerExited">
                                <Grid RowSpacing="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Avatar circle + Label -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                        <Grid Width="36" Height="36">
                                            <Ellipse Fill="{ThemeResource IdentitiesIconBrush}" />
                                            <TextBlock Text=""
                                                       FontSize="16" FontWeight="SemiBold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="{Binding Label}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="190" />
                                    </StackPanel>

                                    <!-- Row 1: Full name (set via ContainerContentChanging) -->
                                    <TextBlock Grid.Row="1"
                                               Text=""
                                               FontSize="16" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />

                                    <!-- Row 2: Email -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Email}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />

                                    <!-- Row 3: Phone (left) + City (right) -->
                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Phone: set via ContainerContentChanging -->
                                        <TextBlock Grid.Column="0"
                                                   Text=""
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding City}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,0,0,0" />
                                    </Grid>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Grid>

        <!-- Save confirmation toast -->
        <TeachingTip x:Name="SavedTip"
                     x:Uid="IdSavedTip"
                     IsLightDismissEnabled="True"
                     PreferredPlacement="Bottom"
                     Title="Salvato!" />

        <!-- Detail panel (right side, 400px) -->
        <Grid x:Name="DetailPanel"
              Grid.Column="1"
              Visibility="Collapsed"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="1,0,0,0">
            <ContentPresenter x:Name="DetailContent" />
        </Grid>
    </Grid>
</UserControl>
