<UserControl
    x:Class="PassKey.Desktop.Views.PasswordDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PassKey.Desktop.Controls">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Scrollable form content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24" Spacing="16">

                <!-- Panel title + subtitle -->
                <StackPanel Spacing="2">
                    <TextBlock x:Name="PanelTitleText"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="PanelSubtitle"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Title (required) -->
                <StackPanel Spacing="6">
                    <TextBlock x:Uid="FieldTitle" Text="Titolo *" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox x:Name="TitleBox"
                             PlaceholderText="Es. Google, Amazon..."
                             TextChanged="TitleBox_TextChanged"
                             AutomationProperties.Name="Titolo"
                             TabIndex="10" />
                </StackPanel>

                <!-- Icon (optional) -->
                <StackPanel Spacing="6">
                    <TextBlock x:Uid="FieldIcon" Text="Icona" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Preview circle — same 3-layer structure as list avatar -->
                        <Grid x:Name="IconPreview" Width="40" Height="40" CornerRadius="20"
                              Background="{ThemeResource PasswordsIconBrush}">
                            <TextBlock x:Name="IconPreviewLetter"
                                       FontSize="16" FontWeight="SemiBold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <FontIcon x:Name="IconPreviewGlyph"
                                      FontSize="18" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Visibility="Collapsed" />
                            <Image x:Name="IconPreviewImage"
                                   Stretch="UniformToFill" Visibility="Collapsed" />
                        </Grid>

                        <!-- Action buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnUploadIcon"
                                    Click="UploadIcon_Click"
                                    AutomationProperties.Name="Carica immagine"
                                    ToolTipService.ToolTip="Carica immagine (PNG, JPG, ICO — max 64 KB)">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xEB9F;" FontSize="14" />
                                    <TextBlock x:Uid="BtnUploadIconLabel" Text="Carica" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnChooseIcon"
                                    AutomationProperties.Name="Scegli icona">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE734;" FontSize="14" />
                                    <TextBlock x:Uid="BtnChooseIconLabel" Text="Scegli icona" />
                                </StackPanel>
                                <Button.Flyout>
                                    <Flyout x:Name="GlyphFlyout" Placement="BottomEdgeAlignedLeft">
                                        <GridView x:Name="IconPickerGrid"
                                                  MaxWidth="288"
                                                  IsItemClickEnabled="True"
                                                  SelectionMode="None"
                                                  ItemClick="IconPickerGrid_ItemClick">
                                            <GridView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="40" Height="40" CornerRadius="4"
                                                            Background="{ThemeResource SubtleFillColorTransparentBrush}">
                                                        <FontIcon Glyph="{Binding}" FontSize="20"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                    </Border>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapGrid MaximumRowsOrColumns="6"
                                                              Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                        </GridView>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <Button x:Name="BtnRemoveIcon"
                                    Click="RemoveIcon_Click"
                                    Visibility="Collapsed"
                                    AutomationProperties.Name="Rimuovi icona"
                                    ToolTipService.ToolTip="Rimuovi icona">
                                <FontIcon Glyph="&#xE711;" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Username (required) -->
                <StackPanel Spacing="6">
                    <TextBlock x:Uid="FieldUsername" Text="Email / User ID *" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox x:Name="UsernameBox"
                             PlaceholderText="email@esempio.it"
                             TextChanged="UsernameBox_TextChanged"
                             AutomationProperties.Name="Email o User ID"
                             TabIndex="20" />
                </StackPanel>

                <!-- Password (required) + Generate button + Strength indicator -->
                <StackPanel Spacing="6">
                    <TextBlock x:Uid="FieldPassword" Text="Password *" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <controls:SecureInputBox
                            x:Name="PasswordInput"
                            Grid.Column="0"
                            PlaceholderText="Password"
                            MaxLength="128"
                            TabIndex="30" />
                        <Button Grid.Column="1"
                                VerticalAlignment="Stretch"
                                Click="GenerateButton_Click"
                                ToolTipService.ToolTip="Genera password"
                                AutomationProperties.Name="Genera password"
                                TabIndex="40">
                            <FontIcon Glyph="&#xE8B1;" FontSize="16" />
                        </Button>
                    </Grid>
                    <TextBlock x:Name="StrengthLabel"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Visibility="Collapsed" />
                </StackPanel>

                <!-- URL -->
                <StackPanel Spacing="6">
                    <TextBlock x:Uid="FieldUrl" Text="URL" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox x:Name="UrlBox"
                             PlaceholderText="https://..."
                             TextChanged="UrlBox_TextChanged"
                             AutomationProperties.Name="URL"
                             TabIndex="50" />
                </StackPanel>

                <!-- Notes -->
                <StackPanel Spacing="6">
                    <TextBlock x:Uid="FieldNotes" Text="Note" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox x:Name="NotesBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="72"
                             MaxHeight="200"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             PlaceholderText="Note aggiuntive..."
                             TextChanged="NotesBox_TextChanged"
                             AutomationProperties.Name="Note"
                             TabIndex="60" />
                </StackPanel>

                <!-- Required field legend -->
                <TextBlock x:Uid="RequiredFieldLegend" Text="* Campo obbligatorio"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Sticky footer with action buttons -->
        <Grid Grid.Row="1" Padding="24,12"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0"
              ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Delete button (only visible in edit mode) -->
            <Button x:Name="DeleteButton"
                    Grid.Column="0"
                    Visibility="Collapsed"
                    Click="DeleteButton_Click"
                    AutomationProperties.Name="Elimina password"
                    TabIndex="70">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource StatRemovedBrush}" />
                    <TextBlock x:Uid="ButtonDeleteLabel" Text="Elimina" Foreground="{ThemeResource StatRemovedBrush}" />
                </StackPanel>
            </Button>

            <!-- Cancel -->
            <Button Grid.Column="2"
                    x:Uid="ButtonCancel"
                    Content="Annulla"
                    Click="CancelButton_Click"
                    AutomationProperties.Name="Annulla"
                    TabIndex="80" />

            <!-- Save -->
            <Button x:Name="SaveButton"
                    Grid.Column="3"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="False"
                    Click="SaveButton_Click"
                    AutomationProperties.Name="Salva"
                    TabIndex="90">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ProgressRing x:Name="SaveProgress"
                                  IsActive="False" Visibility="Collapsed"
                                  Width="14" Height="14" />
                    <TextBlock x:Name="SaveButtonText" x:Uid="ButtonSaveLabel" Text="Salva" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
