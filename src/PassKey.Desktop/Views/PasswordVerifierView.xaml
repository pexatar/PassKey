<UserControl
    x:Class="PassKey.Desktop.Views.PasswordVerifierView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PassKey.Desktop.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Left">

            <!-- Page title -->
            <TextBlock x:Uid="PageVerifier" Text="Verifica password"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,8"
                       AutomationProperties.HeadingLevel="Level1" />

            <!-- Tab selector -->
            <Pivot x:Name="TabPivot">

                <!-- ========== TAB 1: Verifica Password ========== -->
                <PivotItem x:Uid="TabVerify" Header="Verifica">
                    <StackPanel Spacing="16" Margin="0,16,0,0">

                        <!-- ═══ HERO CARD: input + strength ═══ -->
                        <Grid Padding="20"
                              CornerRadius="12"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1">
                            <StackPanel Spacing="16">

                                <!-- SecureInputBox for password input -->
                                <controls:SecureInputBox
                                    x:Name="VerifyPasswordInput"
                                    PlaceholderText="Digita una password per verificarla..."
                                    ShowRevealButton="Visible"
                                    PasswordChanged="VerifyPasswordInput_PasswordChanged"
                                    AutomationProperties.Name="Password da verificare" />

                                <!-- Strength: score + bar + label (visible only when input exists) -->
                                <StackPanel x:Name="ResultsPanel" Spacing="8">

                                    <!-- Score + 5-segment bar + label -->
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Score number -->
                                        <TextBlock x:Name="ScoreText" Grid.Column="0"
                                                   Text="—"
                                                   FontSize="28" FontWeight="Bold"
                                                   VerticalAlignment="Center" />

                                        <!-- 5-segment bar -->
                                        <Grid x:Name="StrengthBarGrid" Grid.Column="1"
                                              ColumnSpacing="4" Height="8" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="StrengthSeg0" Grid.Column="0" CornerRadius="4"
                                                    Background="{ThemeResource ControlStrongFillColorDisabledBrush}" />
                                            <Border x:Name="StrengthSeg1" Grid.Column="1" CornerRadius="4"
                                                    Background="{ThemeResource ControlStrongFillColorDisabledBrush}" />
                                            <Border x:Name="StrengthSeg2" Grid.Column="2" CornerRadius="4"
                                                    Background="{ThemeResource ControlStrongFillColorDisabledBrush}" />
                                            <Border x:Name="StrengthSeg3" Grid.Column="3" CornerRadius="4"
                                                    Background="{ThemeResource ControlStrongFillColorDisabledBrush}" />
                                            <Border x:Name="StrengthSeg4" Grid.Column="4" CornerRadius="4"
                                                    Background="{ThemeResource ControlStrongFillColorDisabledBrush}" />
                                        </Grid>

                                        <!-- Strength label + crack time -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                                    VerticalAlignment="Center">
                                            <TextBlock x:Name="StrengthLabel" Text="—"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       AutomationProperties.LiveSetting="Polite" />
                                            <TextBlock x:Name="CrackTimeText" Text="—"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       AutomationProperties.LiveSetting="Polite" />
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- ═══ REQUISITI (sotto hero card, visibile solo con input) ═══ -->
                        <!-- Privacy note -->
                        <TextBlock Text="La verifica avviene interamente offline, nessun dato viene inviato."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                        <StackPanel x:Name="RequirementsSection" Spacing="8">

                            <!-- Section header with icon -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                                <FontIcon Glyph="&#xE71C;" FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock x:Uid="RequirementsTitle" Text="Requisiti"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           AutomationProperties.HeadingLevel="Level2" />
                            </StackPanel>

                            <!-- 7 checklist items -->
                            <StackPanel Spacing="10">
                                <StackPanel x:Name="CheckMinLength" Orientation="Horizontal" Spacing="10" Opacity="0.45">
                                    <FontIcon x:Name="CheckMinLengthIcon" Glyph="&#xE711;" FontSize="16" />
                                    <TextBlock x:Uid="ReqMinLength" Text="Almeno 8 caratteri"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="CheckRecLength" Orientation="Horizontal" Spacing="10" Opacity="0.45">
                                    <FontIcon x:Name="CheckRecLengthIcon" Glyph="&#xE711;" FontSize="16" />
                                    <TextBlock x:Uid="ReqRecLength" Text="Almeno 12 caratteri (raccomandato)"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="CheckUppercase" Orientation="Horizontal" Spacing="10" Opacity="0.45">
                                    <FontIcon x:Name="CheckUppercaseIcon" Glyph="&#xE711;" FontSize="16" />
                                    <TextBlock x:Uid="ReqUppercase" Text="Contiene lettere maiuscole"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="CheckLowercase" Orientation="Horizontal" Spacing="10" Opacity="0.45">
                                    <FontIcon x:Name="CheckLowercaseIcon" Glyph="&#xE711;" FontSize="16" />
                                    <TextBlock x:Uid="ReqLowercase" Text="Contiene lettere minuscole"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="CheckDigits" Orientation="Horizontal" Spacing="10" Opacity="0.45">
                                    <FontIcon x:Name="CheckDigitsIcon" Glyph="&#xE711;" FontSize="16" />
                                    <TextBlock x:Uid="ReqDigits" Text="Contiene numeri"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="CheckSymbols" Orientation="Horizontal" Spacing="10" Opacity="0.45">
                                    <FontIcon x:Name="CheckSymbolsIcon" Glyph="&#xE711;" FontSize="16" />
                                    <TextBlock x:Uid="ReqSymbols" Text="Contiene simboli speciali"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel x:Name="CheckNoPatterns" Orientation="Horizontal" Spacing="10" Opacity="0.45">
                                    <FontIcon x:Name="CheckNoPatternsIcon" Glyph="&#xE711;" FontSize="16" />
                                    <TextBlock x:Uid="ReqNoPatterns" Text="Nessun pattern comune rilevato"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- ═══ SUGGERIMENTI ═══ -->
                        <StackPanel x:Name="SuggestionsPanel" Spacing="8" Visibility="Collapsed">

                            <!-- Section header with icon -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,4">
                                <FontIcon Glyph="&#xE82F;" FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock x:Uid="SuggestionsTitle" Text="Suggerimenti per migliorare"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           AutomationProperties.HeadingLevel="Level2" />
                            </StackPanel>

                            <StackPanel x:Name="SuggestionsList" Spacing="6" />
                        </StackPanel>

                    </StackPanel>
                </PivotItem>

                <!-- ========== TAB 2: Audit Vault ========== -->
                <PivotItem x:Uid="TabAuditVault" Header="Audit vault">
                    <StackPanel Spacing="24" Margin="0,16,0,0">

                        <!-- Vault score circle -->
                        <Grid HorizontalAlignment="Center">
                            <ProgressRing x:Name="VaultScoreRing"
                                          Width="160" Height="160"
                                          IsIndeterminate="False"
                                          Value="0" Maximum="100"
                                          Background="{ThemeResource ControlStrongFillColorDisabledBrush}" />
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Name="VaultScoreText"
                                           Text="—"
                                           FontSize="40"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="VaultScoreLabelText"
                                           Text=""
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>

                        <!-- Stats cards row -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Total -->
                            <Grid Grid.Column="0" Padding="16" CornerRadius="8"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                HorizontalAlignment="Center" Margin="0,0,0,4">
                                        <Grid Width="28" Height="28" CornerRadius="14"
                                              Background="{ThemeResource PasswordsIconBrush}">
                                            <FontIcon Glyph="&#xE8D7;" FontSize="12" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock x:Uid="AuditTotal" Text="Totali"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="TotalCountText" Text="0"
                                               FontSize="28" FontWeight="Bold"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <!-- Weak -->
                            <Grid Grid.Column="1" Padding="16" CornerRadius="8"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                HorizontalAlignment="Center" Margin="0,0,0,4">
                                        <Grid Width="28" Height="28" CornerRadius="14"
                                              Background="{ThemeResource StatRemovedBrush}">
                                            <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock x:Uid="AuditWeak" Text="Deboli"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="WeakCountText" Text="0"
                                               FontSize="28" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource StatRemovedBrush}" />
                                </StackPanel>
                            </Grid>

                            <!-- Duplicates -->
                            <Grid Grid.Column="2" Padding="16" CornerRadius="8"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                HorizontalAlignment="Center" Margin="0,0,0,4">
                                        <Grid Width="28" Height="28" CornerRadius="14"
                                              Background="{ThemeResource StatModifiedBrush}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12" Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock x:Uid="AuditDuplicate" Text="Riutilizzate"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="DuplicateCountText" Text="0"
                                               FontSize="28" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource StatModifiedBrush}" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Weak passwords expander -->
                        <Expander x:Name="WeakExpander"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14"
                                              Foreground="{ThemeResource StatRemovedBrush}" />
                                    <TextBlock x:Name="WeakExpanderHeaderText"
                                               x:Uid="PasswordVerifierWeakHeader" />
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel x:Name="WeakPasswordsList" Spacing="4" />
                        </Expander>

                        <!-- Duplicate passwords expander -->
                        <Expander x:Name="DuplicateExpander"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="14"
                                              Foreground="{ThemeResource StatModifiedBrush}" />
                                    <TextBlock x:Name="DuplicateExpanderHeaderText"
                                               x:Uid="PasswordVerifierDuplicatesHeader" />
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel x:Name="DuplicateGroupsList" Spacing="8" />
                        </Expander>

                        <!-- Loading indicator -->
                        <ProgressRing x:Name="AuditLoadingRing"
                                      IsActive="False"
                                      Width="40" Height="40"
                                      HorizontalAlignment="Center" />

                        <!-- Empty state -->
                        <TextBlock x:Name="AuditEmptyText"
                                   x:Uid="AuditEmptyText"
                                   Text="Nessuna password nel vault. Aggiungi delle password per eseguire l'audit."
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed" />

                        <!-- Refresh button -->
                        <Button x:Name="RefreshAuditButton"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Center"
                                Click="RefreshAuditButton_Click"
                                Padding="16,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="16" />
                                <TextBlock x:Uid="ButtonRefreshAudit" Text="Aggiorna analisi vault" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </PivotItem>
            </Pivot>
        </StackPanel>
    </ScrollViewer>
</UserControl>
