<UserControl
    x:Class="PassKey.Desktop.Views.PasswordsListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PassKey.Desktop.Controls"
    KeyDown="OnViewKeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="DetailColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <!-- List area -->
        <Grid Grid.Column="0" Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header: Title + Search + Add button -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Uid="PagePasswords" Text="Password"
                           Style="{StaticResource TitleTextBlockStyle}"
                           VerticalAlignment="Center"
                           AutomationProperties.HeadingLevel="Level1" />

                <AutoSuggestBox Grid.Column="1"
                                x:Name="SearchBox"
                                x:Uid="SearchPasswords"
                                PlaceholderText="Cerca password..."
                                QueryIcon="Find"
                                MaxWidth="300"
                                HorizontalAlignment="Right"
                                TextChanged="SearchBox_TextChanged"
                                AutomationProperties.Name="Cerca password" />

                <Button Grid.Column="2"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="AddButton_Click"
                        AutomationProperties.Name="Nuova password"
                        ToolTipService.ToolTip="Nuova password (Ctrl+N)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock x:Uid="AddPasswordLabel" Text="Nuova password" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Column headers (clickable for sort) -->
            <Grid Grid.Row="1" Padding="56,4,8,4" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Uid="PwColTitle" Text="Titolo"
                           Tapped="ColumnHeader_Tapped" Tag="Title"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           />
                <TextBlock Grid.Column="1" x:Uid="PwColUsername" Text="Username"
                           Tapped="ColumnHeader_Tapped" Tag="Username"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           />
                <TextBlock Grid.Column="2" x:Uid="PwColUrl" Text="URL"
                           Tapped="ColumnHeader_Tapped" Tag="Url"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           />
                <TextBlock Grid.Column="3" x:Uid="PwColDate" Text="Modificato"
                           Tapped="ColumnHeader_Tapped" Tag="Date"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           />
            </Grid>

            <!-- Password list -->
            <ListView Grid.Row="2"
                      x:Name="PasswordList"
                      SelectionMode="Single"
                      IsItemClickEnabled="True"
                      ItemClick="PasswordList_ItemClick"
                      ContainerContentChanging="PwList_ContainerContentChanging">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,10" ColumnSpacing="12"
                              PointerEntered="Row_PointerEntered"
                              PointerExited="Row_PointerExited">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>

                            <!-- Col 0: Avatar — letter / glyph / image (set in ContainerContentChanging) -->
                            <Grid Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                  Background="{ThemeResource PasswordsIconBrush}">
                                <!-- Layer 0: first letter of title (default) -->
                                <TextBlock FontSize="14" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <!-- Layer 1: Segoe MDL2 glyph (when FaviconBase64 starts with "glyph:") -->
                                <FontIcon FontSize="16" Foreground="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Visibility="Collapsed" />
                                <!-- Layer 2: custom image (when FaviconBase64 is base64 data) -->
                                <Image Stretch="UniformToFill" Visibility="Collapsed" />
                            </Grid>

                            <!-- Col 1: Title -->
                            <TextBlock Grid.Column="1" Text="{Binding Title}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />

                            <!-- Col 2: Username -->
                            <TextBlock Grid.Column="2" Text="{Binding Username}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />

                            <!-- Col 3: URL -->
                            <TextBlock Grid.Column="3" Text="{Binding Url}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />

                            <!-- Col 4: Date / Hover actions (overlapping) -->
                            <Grid Grid.Column="4" VerticalAlignment="Center">
                                <TextBlock x:Name="DateText"
                                           Text="{Binding ModifiedAt, Converter={StaticResource DateFormatConverter}}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center" />
                                <StackPanel x:Name="HoverActions"
                                            Orientation="Horizontal" Spacing="2"
                                            Opacity="0" VerticalAlignment="Center">
                                    <Button ToolTipService.ToolTip="Copia username"
                                            Click="CopyUsername_Click"
                                            Tag="{Binding}"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                    </Button>
                                    <Button ToolTipService.ToolTip="Copia password"
                                            Click="CopyPassword_Click"
                                            Tag="{Binding}"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4">
                                        <FontIcon Glyph="&#xE8D7;" FontSize="12" />
                                    </Button>
                                    <Button ToolTipService.ToolTip="Modifica"
                                            Click="EditEntry_Click"
                                            Tag="{Binding}"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Padding="4">
                                        <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <controls:EmptyStateControl
                x:Name="EmptyState"
                Grid.Row="2"
                Visibility="Collapsed"
                Icon="&#xE8D7;"
                Title="Nessuna password salvata"
                Subtitle="Aggiungi la tua prima password per iniziare a proteggere i tuoi account."
                PrimaryActionText="Nuova password" />
        </Grid>

        <!-- Detail panel (right side, 400px) -->
        <Grid x:Name="DetailPanel"
              Grid.Column="1"
              Visibility="Collapsed"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="1,0,0,0">
            <ContentPresenter x:Name="DetailContent" />
        </Grid>

        <!-- Save confirmation toast -->
        <TeachingTip x:Name="SavedTip"
                     x:Uid="PwSavedTip"
                     IsLightDismissEnabled="True"
                     PreferredPlacement="Bottom"
                     Title="Salvato!" />
    </Grid>
</UserControl>
