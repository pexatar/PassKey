<Application
    x:Class="PassKey.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PassKey.Desktop.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/ThemeColors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:InverseBoolConverter x:Key="InverseBool" />
            <converters:BooleanToVisibilityConverter x:Key="IsNotNullToVisibility" />
            <converters:DateFormatConverter x:Key="DateFormatConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
