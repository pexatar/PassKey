<Window
    x:Class="PassKey.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon"
    Title="PassKey">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ContentPresenter x:Name="RootPresenter" />
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            ToolTipText="PassKey">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        Text="Mostra PassKey"
                        Command="{x:Bind TrayShowCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        Text="Blocca Vault"
                        Command="{x:Bind TrayLockCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        Text="Esci"
                        Command="{x:Bind TrayExitCommand}" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
