<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <!-- Light theme -->
        <ResourceDictionary x:Key="Light">
            <!-- Stat card icon colors -->
            <SolidColorBrush x:Key="PasswordsIconBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="CardsIconBrush" Color="#8764B8" />
            <SolidColorBrush x:Key="IdentitiesIconBrush" Color="#00B294" />
            <SolidColorBrush x:Key="NotesIconBrush" Color="#FFB900" />

            <!-- Stat delta colors -->
            <SolidColorBrush x:Key="StatAddedBrush" Color="#388E3C" />
            <SolidColorBrush x:Key="StatRemovedBrush" Color="#C62828" />
            <SolidColorBrush x:Key="StatModifiedBrush" Color="#F57C00" />

            <!-- Password strength gradient -->
            <SolidColorBrush x:Key="StrengthVeryWeakBrush" Color="#C62828" />
            <SolidColorBrush x:Key="StrengthWeakBrush" Color="#E65100" />
            <SolidColorBrush x:Key="StrengthMediumBrush" Color="#F57C00" />
            <SolidColorBrush x:Key="StrengthStrongBrush" Color="#388E3C" />
            <SolidColorBrush x:Key="StrengthVeryStrongBrush" Color="#1B5E20" />

            <!-- Password character syntax coloring -->
            <SolidColorBrush x:Key="PasswordCharLetterBrush" Color="#1B1B1B" />
            <SolidColorBrush x:Key="PasswordCharDigitBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="PasswordCharSymbolBrush" Color="#E65100" />

            <!-- Card text on color background -->
            <SolidColorBrush x:Key="CardTextOnColorBrush" Color="#000000" />

            <!-- Check pass/fail (checklist items) -->
            <SolidColorBrush x:Key="CheckPassBrush" Color="#388E3C" />
            <SolidColorBrush x:Key="CheckFailBrush" Color="#9E9E9E" />

            <!-- Luhn validation colors -->
            <SolidColorBrush x:Key="LuhnValidBrush" Color="#388E3C" />
            <SolidColorBrush x:Key="LuhnInvalidBrush" Color="#C62828" />

            <!-- Color swatch selected border -->
            <SolidColorBrush x:Key="ColorSwatchSelectedBorderBrush" Color="#000000" />
        </ResourceDictionary>

        <!-- Dark theme (Default) -->
        <ResourceDictionary x:Key="Default">
            <!-- Stat card icon colors -->
            <SolidColorBrush x:Key="PasswordsIconBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="CardsIconBrush" Color="#8764B8" />
            <SolidColorBrush x:Key="IdentitiesIconBrush" Color="#00B294" />
            <SolidColorBrush x:Key="NotesIconBrush" Color="#FFB900" />

            <!-- Stat delta colors -->
            <SolidColorBrush x:Key="StatAddedBrush" Color="#81C784" />
            <SolidColorBrush x:Key="StatRemovedBrush" Color="#E57373" />
            <SolidColorBrush x:Key="StatModifiedBrush" Color="#FF9800" />

            <!-- Password strength gradient -->
            <SolidColorBrush x:Key="StrengthVeryWeakBrush" Color="#E57373" />
            <SolidColorBrush x:Key="StrengthWeakBrush" Color="#FF9800" />
            <SolidColorBrush x:Key="StrengthMediumBrush" Color="#FFB74D" />
            <SolidColorBrush x:Key="StrengthStrongBrush" Color="#81C784" />
            <SolidColorBrush x:Key="StrengthVeryStrongBrush" Color="#4CAF50" />

            <!-- Password character syntax coloring -->
            <SolidColorBrush x:Key="PasswordCharLetterBrush" Color="#E0E0E0" />
            <SolidColorBrush x:Key="PasswordCharDigitBrush" Color="#60CDFF" />
            <SolidColorBrush x:Key="PasswordCharSymbolBrush" Color="#FFB74D" />

            <!-- Card text on color background -->
            <SolidColorBrush x:Key="CardTextOnColorBrush" Color="#FFFFFF" />

            <!-- Check pass/fail (checklist items) -->
            <SolidColorBrush x:Key="CheckPassBrush" Color="#81C784" />
            <SolidColorBrush x:Key="CheckFailBrush" Color="#9E9E9E" />

            <!-- Luhn validation colors -->
            <SolidColorBrush x:Key="LuhnValidBrush" Color="#4CAF50" />
            <SolidColorBrush x:Key="LuhnInvalidBrush" Color="#DC3545" />

            <!-- Color swatch selected border -->
            <SolidColorBrush x:Key="ColorSwatchSelectedBorderBrush" Color="#FFFFFF" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Spacing tokens -->
    <x:Double x:Key="SpacingXSmall">4</x:Double>
    <x:Double x:Key="SpacingSmall">8</x:Double>
    <x:Double x:Key="SpacingMedium">12</x:Double>
    <x:Double x:Key="SpacingLarge">16</x:Double>
    <x:Double x:Key="SpacingXLarge">24</x:Double>
    <x:Double x:Key="SpacingXXLarge">32</x:Double>
    <x:Double x:Key="SpacingXXXLarge">48</x:Double>

    <!-- Custom text styles -->
    <Style x:Key="DisplayTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MonospaceTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Mono" />
        <Setter Property="FontSize" Value="18" />
    </Style>

</ResourceDictionary>
