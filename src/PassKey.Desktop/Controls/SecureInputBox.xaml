<UserControl
    x:Class="PassKey.Desktop.Controls.SecureInputBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBox
            x:Name="InputBox"
            Grid.Column="0"
            TextChanged="InputBox_TextChanged"
            KeyDown="InputBox_KeyDown" />

        <Border
            x:Name="RevealButton"
            Grid.Column="1"
            Background="Transparent"
            VerticalAlignment="Center"
            Margin="4,0,0,0"
            Padding="6"
            CornerRadius="4"
            PointerPressed="RevealButton_PointerPressed"
            PointerReleased="RevealButton_PointerReleased"
            PointerExited="RevealButton_PointerExited"
            AutomationProperties.Name="Reveal password">
            <FontIcon Glyph="&#xE7B3;" FontSize="16" />
        </Border>
    </Grid>
</UserControl>
