<UserControl
    x:Class="PassKey.Desktop.Controls.CreditCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Skeuomorphic credit card visual (SC-08) — flat layout, zero nesting -->
    <Grid x:Name="CardRoot"
          Width="300" Height="190"
          CornerRadius="16"
          Padding="20,16,20,16">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="GradientStart" Color="#37474F" Offset="0" />
                <GradientStop x:Name="GradientEnd" Color="#263238" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Row 0: Card type -->
            <RowDefinition Height="*" />      <!-- Row 1: PAN centered -->
            <RowDefinition Height="Auto" />   <!-- Row 2: Labels (CARDHOLDER/EXPIRY) -->
            <RowDefinition Height="Auto" />   <!-- Row 3: Values (name/date) -->
            <RowDefinition Height="Auto" />   <!-- Row 4: Label + Badge -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Row 0: Card type (right-aligned, spans columns) -->
        <TextBlock x:Name="CardTypeText"
                   Grid.Row="0" Grid.ColumnSpan="2"
                   HorizontalAlignment="Right"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="White"
                   Opacity="0.9"
                   Text="CARD" />

        <!-- Row 1: Masked PAN (centered vertically, spans columns) -->
        <TextBlock x:Name="MaskedPanText"
                   Grid.Row="1" Grid.ColumnSpan="2"
                   VerticalAlignment="Center"
                   FontSize="20"
                   FontFamily="Cascadia Mono, Consolas"
                   Foreground="White"
                   CharacterSpacing="60"
                   Text="•••• •••• •••• ••••" />

        <!-- Row 2: Labels -->
        <TextBlock x:Name="CardholderLabel"
                   Grid.Row="2" Grid.Column="0"
                   Text="CARDHOLDER"
                   FontSize="8" Foreground="White" Opacity="0.6" />
        <TextBlock x:Name="ExpiryLabel"
                   Grid.Row="2" Grid.Column="1"
                   Text="EXPIRY"
                   FontSize="8" Foreground="White" Opacity="0.6"
                   HorizontalAlignment="Right" />

        <!-- Row 3: Values -->
        <TextBlock x:Name="CardholderText"
                   Grid.Row="3" Grid.Column="0"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="White"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,2,8,0" />
        <TextBlock x:Name="ExpiryText"
                   Grid.Row="3" Grid.Column="1"
                   FontSize="12" FontWeight="SemiBold"
                   Foreground="White"
                   HorizontalAlignment="Right"
                   Margin="0,2,0,0" />

        <!-- Row 4: Label + Category badge -->
        <TextBlock x:Name="LabelText"
                   Grid.Row="4" Grid.Column="0"
                   FontSize="11"
                   Foreground="White"
                   Opacity="0.7"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,4,8,0" />

        <Border x:Name="CategoryBadge"
                Grid.Row="4" Grid.Column="1"
                Background="#33FFFFFF"
                CornerRadius="4"
                Padding="6,3"
                VerticalAlignment="Center"
                Margin="0,4,0,0">
            <TextBlock x:Name="CategoryText"
                       FontSize="9"
                       FontWeight="SemiBold"
                       Foreground="White" />
        </Border>
    </Grid>
</UserControl>
